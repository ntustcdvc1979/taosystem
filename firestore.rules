rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ===== 授權白名單 =====
    // 只有下面清單裡的 Google 帳號 Email 才能存取資料。
    // 要新增使用者：把對方的 Google Email 加到這個陣列裡，然後重新發布規則。
    function isAllowed() {
      return request.auth != null &&
             request.auth.token.email in [
               'damoncho510@gmail.com'
               // , 'someone@gmail.com'
               // , 'another@gmail.com'
             ];
    }

    match /entries/{entryId} {
      allow read, write: if isAllowed();
    }

    // 共用設定（含 AI 的共用 API Key，存在 config/ai 文件的 anthropicApiKey 欄位）。
    // 只有白名單成員能讀取；寫入僅限透過 Firebase Console（管理員）操作。
    match /config/{docId} {
      allow read: if isAllowed();
      allow write: if false;
    }

    // 近期活動（活動管理頁維護：名稱、日期、類型），白名單成員可讀寫
    match /events/{eventId} {
      allow read, write: if isAllowed();
    }

    // AI 成全助手的對話紀錄，每位使用者一份（文件 ID = 使用者 uid）。
    // 除了要在白名單內，還限定只能讀寫自己那一份，看不到別人的對話。
    match /chatHistories/{userId} {
      allow read, write: if isAllowed() && request.auth.uid == userId;
    }

    // 其他所有路徑一律拒絕
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
