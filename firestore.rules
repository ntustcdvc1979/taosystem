rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ===== 授權白名單 =====
    // 只有下面清單裡的 Google 帳號 Email 才能存取資料。
    // 要新增使用者：把對方的 Google Email 加到這個陣列裡，然後重新發布規則。
    function isAllowed() {
      return request.auth != null &&
             request.auth.token.email in [
               'damoncho510@gmail.com'
               // , 'someone@gmail.com'
               // , 'another@gmail.com'
             ];
    }

    match /entries/{entryId} {
      allow read, write: if isAllowed();
    }

    // 共用設定（含 AI 的共用 API Key，存在 config/ai 文件的 anthropicApiKey 欄位）。
    // 只有白名單成員能讀取；寫入僅限透過 Firebase Console（管理員）操作。
    match /config/{docId} {
      allow read: if isAllowed();
      allow write: if false;
    }

    // 送給 AI 前要遮罩的自訂詞彙（例：學校/單位簡稱）。白名單成員可自行新增/刪除。
    match /deidentifyTerms/{termId} {
      allow read, write: if isAllowed();
    }

    // 其他所有路徑一律拒絕
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
